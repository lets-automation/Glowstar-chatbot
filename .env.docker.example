# =====================================================================
# GlowStar chatbot — environment template for the Docker Compose stack.
# Copy this to `.env`, fill in the real values, and never commit `.env`.
#   cp .env.docker.example .env
# =====================================================================

# ----- Database (AasthaErp SQL Server) -----
# By default the backend connects to your REAL SQL Server (docker-compose.yml
# sets DB_SERVER=host.docker.internal, DB_USER=glowstar_ro). It uses a READ-ONLY
# login you create on the DB (reads AasthaErp, cannot write). Put that login's
# password here:
DB_RO_PASSWORD=CHANGE_ME_readonly_login_password
DB_NAME=AasthaErp
DB_DRIVER=ODBC Driver 18 for SQL Server
#
# The SQL Server must accept network (TCP) + SQL-login connections. On a real
# server that's normally already on; on a locked-down dev box you may need to
# enable mixed-mode auth + TCP/IP + a read-only login (see PRODUCTION.md).
# On a Linux host, set DB_SERVER in docker-compose.yml to the DB's real address.
#
# OPTIONAL bundled db container (self-contained copy) — only used with
# `docker compose --profile bundled-db up`. Its "sa" password (8+ chars,
# upper+lower+digit+symbol):
DB_SA_PASSWORD=CHANGE_ME_Str0ng!Pass

# ----- LLM provider -----
# groq (free testing) | gemini (free fallback, tiny quota) | anthropic (Claude, paid)
LLM_PROVIDER=groq
SCHEMA_MAX_COLS=30
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ----- Redis (sessions, user accounts, rate limits) -----
# In Compose this is overridden to redis://redis:6379/0 automatically.
REDIS_URL=redis://redis:6379/0

# ----- Authentication -----
# OFF by default: no login screen, open API. Set true for the built-in
# username/password login or to gate the API for a CRM/SSO integration.
AUTH_ENABLED=false
# Used only when AUTH_ENABLED=true. Generate one long random value, keep secret,
# same across restarts/instances:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_run_the_command_above
JWT_EXPIRE_MINUTES=720
RATE_LIMIT_PER_MINUTE=20

# ----- CORS -----
# In the Docker stack the browser talks to nginx (same origin), so this is not
# used there. Only relevant if the backend is exposed directly to a browser on
# another origin. "*" for local dev only; set real origin(s) otherwise.
CORS_ORIGINS=*
