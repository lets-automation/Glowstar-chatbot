# Never bake secrets or local state into an image layer.
.env
.env.*
!.env.docker.example

# Local dev artifacts - irrelevant or huge inside a container.
venv/
node_modules/
frontend/dist/
frontend/node_modules/
__pycache__/
*.pyc
.pytest_cache/
outputs/
logs/
.git/
.gitignore

# NEVER bake the operator's data/backups or generated reports into the image
# ("COPY . ." would otherwise ship the real AasthaErp backup + exports).
db_backup/
artifacts/
*.bak
*.mdf
*.ldf
*.xlsx
*.pdf
tests/

# Editor/OS cruft
.vscode/
.idea/
*.swp
.DS_Store
